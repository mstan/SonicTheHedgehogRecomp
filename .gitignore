# Local-dev engine override: an optional symlink (engine-local ->
# ../segagenesisrecomp) that lets all game repos share ONE engine checkout.
# Gitignored — the committed public layout is the `segagenesisrecomp`
# submodule, so `clone --recursive` is self-contained. CMake prefers
# engine-local when present. Create it with scripts/link-engine.{sh,bat}.
engine-local
